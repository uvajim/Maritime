# cairo-erc20 — Hardhat environment variable template.
#
# Copy to .env for local development (gitignored). Hardhat reads these via
# `configVariable(...)` in hardhat.config.ts. NEVER commit real private keys
# or RPC URLs with embedded API keys — use .env locally and CI secrets
# (namespaced <NAME>__<DEV|BETA|MAIN>, see docs/SECRETS.md) elsewhere.
#
# Contract deployment is a manual/local process for now (CI only compiles +
# tests this package) — see docs/DEPLOYMENT.md.

# ── Networks ──────────────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_key_here
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your_key_here

# ── Accounts (index 0/1/2 used by sepolia & mainnet networks) ────────────────
# index 0 — deploys contracts
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
# index 1 — deposits / withdraws (test/interaction accounts)
USER_PRIVATE_KEY=your_user_private_key_here
# index 2 — vault, pre-approves contract
VAULT_PRIVATE_KEY=your_vault_private_key_here

# ── Verification ──────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# ── Deployed contract addresses (used by scripts/) ───────────────────────────
CONTRACT_ADDRESS=
OVERSEER_ADDRESS=
EQUITY_VAULT_ADDRESS=
TRADE_EXECUTOR_ADDRESS=
MDT_TOKEN_ADDRESS=

# ── Script parameters (scripts/*.ts, *.js) ────────────────────────────────────
USER_ADDRESS=
USER_ID=
OWNER_WALLET=
VAULT_WALLET=
BACKEND_SIGNER_ADDRESS=
FROM=
TO=
TOKEN=
AMOUNT=
