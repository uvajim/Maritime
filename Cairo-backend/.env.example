# Bridge API
# Get from https://dashboard.bridge.xyz → API Keys
BRIDGE_API_KEY=your_bridge_api_key_here

# Alpaca API credentials
# Get these from https://app.alpaca.markets → API Keys
APCA_API_KEY_ID=your_alpaca_key_id_here
APCA_API_SECRET_KEY=your_alpaca_secret_key_here

# Set to "false" to switch to live trading (remove for paper/demo)
ALPACA_PAPER=true

# BIP-39 mnemonic for HD wallet deposit address generation
# Generate one at: https://iancoleman.io/bip39/
# NEVER commit the real value — keep it in .env only
WALLET_MNEMONIC=word1 word2 word3 ... word12

# Plaid credentials
# Get these from https://dashboard.plaid.com → Team Settings → Keys
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_sandbox_secret_here
PLAID_ENV=sandbox

# WeChat Pay via Airwallex
# Get credentials from https://www.airwallex.com/app → Settings → API Keys
# Leave AIRWALLEX_ENV unset (or set to "demo") to use the sandbox;
# set to "production" only when going live.
WECHAT_PAY_PROVIDER=airwallex
AIRWALLEX_ENV=demo
AIRWALLEX_CLIENT_ID=your_airwallex_client_id_here
AIRWALLEX_API_KEY=your_airwallex_api_key_here
AIRWALLEX_WEBHOOK_SECRET=your_airwallex_webhook_secret_here

# Express server port
PORT=3001

# MDT token contract address (MaritimeDeposit) — used by server.js
MDT_CONTRACT_ADDRESS=0xE7ef0924D1545515cA322E613D66CcC269CF6010

# ── TypeScript backend (src/) ──────────────────────────────────────────────────

# Chain
CHAIN_ID=11155111
RPC_URL=https://sepolia.infura.io/v3/your_key_here

# Contract addresses (Sepolia)
OVERSEER_ADDRESS=your_overseer_address_here
EQUITY_VAULT_ADDRESS=0xdAFED1Eab28d02859862E4A8cE09995B16A01DDF
MDT_ADDRESS=0xE7ef0924D1545515cA322E613D66CcC269CF6010

# EIP-712 offer signing key — NEVER used to send transactions
BACKEND_SIGNER_PRIVATE_KEY=your_backend_signer_private_key_here

# Operator wallet — sends mint/burn/compliance transactions to EquityVault
# Must hold MINTER_ROLE on EquityVault. Keep this in a secrets manager in production.
OPERATOR_PRIVATE_KEY=your_operator_private_key_here

# Admin API key — required to set prices via POST /api/admin/price
ADMIN_API_KEY=your_admin_api_key_here

# Offer expiry window in seconds (default 120)
OFFER_TTL=120