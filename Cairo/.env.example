# ─────────────────────────────────────────────────────────────────────────────
# Cairo — Next.js Frontend  ·  Environment Variables
#
# Copy this file to .env.local (dev) and never commit real values.
# In CI/CD: variables are injected from GitHub/Gitea Environment secrets.
# In Vercel: variables are set via the dashboard or the sync-env job in deploy.yml.
#
# NEXT_PUBLIC_* vars are embedded at BUILD TIME and visible in the browser.
# Server-only vars (no NEXT_PUBLIC_ prefix) stay server-side only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the Cairo-backend Express API.
# dev:  http://localhost:3001
# beta: https://cairo-backend-beta.up.railway.app
# main: https://cairo-backend-production-67f8.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ── Web3 / Wallet Connect ─────────────────────────────────────────────────────
# Get from https://cloud.reown.com → Projects → WalletConnect Project ID
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# EVM chain ID
# dev/beta: 11155111 (Sepolia)
# main:     1 (Mainnet)
NEXT_PUBLIC_CHAIN_ID=11155111

# ── Contract Addresses ────────────────────────────────────────────────────────
# Update after each contract deployment. See cairo-erc20 deployment scripts.
NEXT_PUBLIC_OVERSEER_ADDRESS=your_overseer_address_here
NEXT_PUBLIC_EQUITY_VAULT_ADDRESS=your_equity_vault_address_here
NEXT_PUBLIC_MDT_ADDRESS=your_mdt_address_here

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get from https://console.firebase.google.com → Project Settings → General → Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# ── App Mode ──────────────────────────────────────────────────────────────────
# dev | beta | production
NEXT_PUBLIC_APP_ENV=development
