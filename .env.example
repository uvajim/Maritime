# ─────────────────────────────────────────────────────────────────────────────
# Maritime (root) — Docker Compose / Monorepo Environment Variables
#
# Copy to .env and fill in values for local docker-compose development.
# Each package also has its own .env.example for standalone use.
# ─────────────────────────────────────────────────────────────────────────────

# ── Compose-level ─────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=maritime

# ── Cairo-backend (passed into the container) ─────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development
CHAIN_ID=11155111

# Ethereum RPC
RPC_URL=https://sepolia.infura.io/v3/your_infura_key_here

# Contract addresses (Sepolia)
OVERSEER_ADDRESS=your_overseer_address_here
EQUITY_VAULT_ADDRESS=your_equity_vault_address_here
MDT_ADDRESS=your_mdt_address_here

# Keys — NEVER commit real values
BACKEND_SIGNER_PRIVATE_KEY=0x_your_backend_signer_private_key_here
OPERATOR_PRIVATE_KEY=0x_your_operator_private_key_here
ADMIN_API_KEY=your_admin_api_key_here

# Bridge / Alpaca / Plaid / Airwallex — see Cairo-backend/.env.example
BRIDGE_API_KEY=your_bridge_api_key_here
APCA_API_KEY_ID=your_alpaca_key_id_here
APCA_API_SECRET_KEY=your_alpaca_secret_key_here
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
AIRWALLEX_CLIENT_ID=your_airwallex_client_id_here
AIRWALLEX_API_KEY=your_airwallex_api_key_here

# ── Cairo (Next.js) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=maritime
POSTGRES_PASSWORD=maritime
POSTGRES_DB=maritime
